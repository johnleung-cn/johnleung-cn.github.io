---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<BaseLayout title="My Blog" description="A personal blog powered by Astro and Cloudflare Pages">
  <section class="hero">
    <h1>Welcome </h1>
    <p>A personal blog powered by Astro, Cloudflare Pages with built-in image hosting.</p>
  </section>

  <section class="post-list">
    <h2>Recent posts</h2>
    <ul>
      {
        posts.map((post) => (
          <li>
            <article class="post-card">
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString("zh-CN", {
                  year: "numeric",
                  month: "2-digit",
                  day: "2-digit",
                })}
              </time>
              <h3>
                <a href={`/blog/${post.id}`}>{post.data.title}</a>
              </h3>
              <p>{post.data.description}</p>
              {
                post.data.tags?.length > 0 && (
                  <div class="tags">
                    {post.data.tags.map((tag: string) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )
              }
            </article>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
